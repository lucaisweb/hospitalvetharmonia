# URL do Google Apps Script Web App que recebe os leads da LP /contato.
# Como obter: ver SETUP_LEADS.md
#
# ⚠️ IMPORTANTE: SEM o prefixo VITE_ — essa variável é lida APENAS pela
# Vercel Function em api/lead.ts (server-side). Ela NUNCA vai pro bundle
# do cliente, então a URL do Apps Script fica escondida do navegador.
#
# Exemplo:
# LEADS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbxXXXXXXXXXXXXXXXXXXXX/exec

LEADS_WEBHOOK_URL=
